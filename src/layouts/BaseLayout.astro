---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  ogImage,
  canonical,
  ogType = 'website',
  publishedTime,
  jsonLd,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://szmidtke.pl';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
// OG default z satori-generated /og-default.png (spec §11).
// Per-wpis OG przekazywany jawnie (patrz [...slug].astro).
const ogImageUrl = ogImage ?? new URL('/og-default.png', siteUrl).toString();
const fullTitle = title.includes('Marcin Szmidtke') ? title : `${title} — Marcin Szmidtke`;

// JSON-LD defaults to Person schema on every page
const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Marcin Szmidtke',
  url: siteUrl,
  description: 'Piszę o pasywności, schematach, drodze bez mety. Prowadzę zespół, działam w Fundacji Pomocja.',
  sameAs: [
    'https://www.linkedin.com/in/marcin-szmidtke',
    'https://github.com/ochhyes',
  ],
};
const structuredData = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Marcin Szmidtke" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="pl_PL" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon (placeholder — docelowy SVG w iteracji 10) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS alternate (endpoint wejdzie w iteracji 6) -->
    <link rel="alternate" type="application/rss+xml" title="szmidtke.pl — RSS" href="/rss.xml" />

    <!-- Fonty Google: Newsreader (główny) + preconnect.
         Google Fonts CSS sam serwuje subset latin-ext dla polskich znaków
         na podstawie unicode-range w pobieranym CSS — nie trzeba jawnego parametru. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500;1,6..72,600&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500;1,6..72,600&display=swap"
      rel="stylesheet"
    />

    <!-- Inline theme setter — ustawia data-theme przed paintem (no FOUC) -->
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('theme');
          if (saved === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else if (saved === 'light') {
            document.documentElement.removeAttribute('data-theme');
          }
          // Brak saved → zdany na prefers-color-scheme z CSS.
        } catch (e) {}
      })();
    </script>

    <!-- JSON-LD structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <slot name="head" />
  </head>

  <body>
    <a href="#main" class="skip-link">Przejdź do treści</a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
