---
// Widget statusu książki *Nie ja*. Horizontal progress, 5 etapów.
// Marker [STATUS: nie-ja-etap] żeby łatwo zmieniać copy pod paskiem.

type Stage = 'szkic' | 'rekopis' | 'redakcja' | 'korekta' | 'druk';

interface Props {
  current?: Stage;
}

const { current = 'redakcja' } = Astro.props;

const STAGES: { key: Stage; label: string; caption: string }[] = [
  { key: 'szkic', label: 'szkic', caption: 'pierwsze wersje rozdziałów, próbuję tonu.' },
  { key: 'rekopis', label: 'rękopis', caption: 'całość spisana, układa się w książkę.' },
  { key: 'redakcja', label: 'redakcja', caption: 'rękopis u redaktora — przecinamy, ważymy zdania.' },
  { key: 'korekta', label: 'korekta', caption: 'ostatni przegląd przed drukiem — literówki, spójność.' },
  { key: 'druk', label: 'druk', caption: 'książka trafia na półki.' },
];

const currentIdx = STAGES.findIndex((s) => s.key === current);
const currentStage = STAGES[currentIdx];
---

<section class="nie-ja-status" aria-label={`Status książki Nie ja: ${currentStage.label}`}>
  <ol class="steps">
    {STAGES.map((stage, idx) => {
      const state = idx < currentIdx ? 'past' : idx === currentIdx ? 'current' : 'upcoming';
      return (
        <li class={`step step--${state}`} aria-current={state === 'current' ? 'step' : undefined}>
          <span class="bar"></span>
          <span class="label">{stage.label}</span>
        </li>
      );
    })}
  </ol>
  <p class="caption">{currentStage.caption}</p>
</section>

<style>
  .nie-ja-status {
    max-width: var(--reading-w);
    margin: 48px auto 0;
    padding: 0 12px;
  }
  .steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (min-width: 640px) {
    .steps { gap: 14px; }
  }
  .step {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: stretch;
  }
  .bar {
    display: block;
    height: 3px;
    border-radius: 2px;
    background: var(--border);
  }
  .step--past .bar { background: var(--text-muted); }
  .step--current .bar { background: var(--accent); }
  .label {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--text-muted);
    text-align: center;
    letter-spacing: 0.01em;
  }
  @media (min-width: 640px) {
    .label { font-size: 15px; }
  }
  .step--current .label {
    color: var(--accent);
  }
  .caption {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--text-muted);
    text-align: center;
    font-size: 15px;
    line-height: 1.6;
    margin-top: 20px;
  }
</style>
