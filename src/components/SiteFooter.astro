---
// Footer globalny — 3-kolumnowy grid (desktop) → 1-kolumnowy (mobile).
// Kolumna 3 zawiera theme toggle. Spec §5.7.
const year = new Date().getFullYear();
---

<footer class="site">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h2>O stronie</h2>
        <p>Pisze Marcin Szmidtke.</p>
        <p>Bez trackerów, bez cookies analitycznych, bez reklam. Jeżeli widzisz coś, co śledzi — <a href="/kontakt">zgłoś</a>.</p>
        <a href="/prywatnosc">prywatność</a>
      </div>
      <div>
        <h2>Nawigacja</h2>
        <a href="/blog">piszę</a>
        <a href="/blog/spis">spis</a>
        <a href="/o-mnie">o mnie</a>
        <a href="/nie-ja">nie ja</a>
        <a href="/pomocja">pomocja</a>
        <a href="/#newsletter">newsletter</a>
        <a href="/kontakt">kontakt</a>
        <a href="/rss.xml">rss</a>
        <a href="/atom.xml">atom</a>
      </div>
      <div>
        <h2>Kontakt</h2>
        <a href="mailto:kontakt@szmidtke.pl">kontakt@szmidtke.pl</a>
        <a href="https://www.linkedin.com/in/marcin-szmidtke" rel="me noopener">linkedin</a>
        <button class="theme-toggle" data-theme-toggle title="Przełącz motyw jasny/ciemny">
          <span data-theme-label>tryb ciemny ↺</span>
        </button>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} Marcin Szmidtke. Teksty moje — jeśli chcesz cytować, zacytuj.</span>
      <span>zbudowane w Astro · <a href="https://github.com/ochhyes/szmidtkepl" rel="noopener">źródła na GitHubie</a></span>
    </div>
  </div>
</footer>

<script is:inline>
  (() => {
    const btn = document.querySelector('[data-theme-toggle]');
    const label = document.querySelector('[data-theme-label]');
    if (!btn || !label) return;

    // "Efektywny" motyw: jawny data-theme jeśli user wybrał, w przeciwnym
    // razie to co OS zgłasza przez prefers-color-scheme. Dzięki temu przy
    // OS=dark i braku zapisu pierwszy klik naprawdę przełącza na jasny.
    const mq = window.matchMedia('(prefers-color-scheme: dark)');
    const isEffectivelyDark = () => {
      const attr = document.documentElement.getAttribute('data-theme');
      if (attr === 'dark') return true;
      if (attr === 'light') return false;
      return mq.matches;
    };

    const sync = () => {
      label.textContent = isEffectivelyDark() ? 'tryb jasny ↺' : 'tryb ciemny ↺';
    };
    sync();

    btn.addEventListener('click', () => {
      const next = isEffectivelyDark() ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
      sync();
    });

    // OS przełączony w locie (bez zapisu) — odśwież label.
    mq.addEventListener?.('change', () => {
      if (!localStorage.getItem('theme')) sync();
    });
  })();
</script>
