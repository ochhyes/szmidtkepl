---
// Wrapper na renderowane MDX. Drop cap na pierwszym <p> — dodajemy klasę
// .has-dropcap przez CSS :first-of-type (bez rehype pluginu, prostsze i stabilne).
---

<div class="post-body">
  <slot />
</div>

<style is:global>
  .post-body {
    max-width: 100%;
  }

  .post-body > p {
    margin-bottom: 24px;
    font-size: 19px;
    line-height: 1.75;
    color: var(--text);
  }

  /* Drop cap — pierwszy akapit body (lead renderowany osobno w [slug].astro,
     więc :first-of-type p trafia w pierwszy akapit treści) */
  .post-body > p:first-of-type::first-letter {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 5.2em;
    float: left;
    line-height: 0.85;
    padding: 6px 14px 0 0;
    color: var(--accent);
  }

  .post-body h2 {
    font-size: 28px;
    font-weight: 500;
    margin: 56px 0 20px;
    letter-spacing: -0.01em;
  }
  .post-body h3 {
    font-size: 24px;
    font-weight: 500;
    margin: 48px 0 16px;
    letter-spacing: -0.01em;
  }
  .post-body h4 {
    font-size: 20px;
    font-weight: 500;
    margin: 40px 0 12px;
    letter-spacing: -0.01em;
    font-style: italic;
  }

  .post-body blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 28px;
    font-style: italic;
    margin: 40px 0;
    color: var(--text-secondary);
    font-size: 21px;
    line-height: 1.55;
  }

  .post-body ul, .post-body ol {
    margin: 0 0 24px;
    padding-left: 28px;
  }
  .post-body ul { list-style: none; }
  .post-body ul li {
    position: relative;
    margin-bottom: 8px;
  }
  .post-body ul li::before {
    content: '·';
    position: absolute;
    left: -18px;
    color: var(--accent);
    font-weight: 600;
  }
  .post-body ol li { margin-bottom: 8px; }

  .post-body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .post-body code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg-alt);
    padding: 2px 6px;
    border-radius: 3px;
  }
  .post-body pre {
    font-family: var(--font-mono);
    background: var(--bg-alt);
    padding: 24px;
    overflow-x: auto;
    margin: 32px 0;
    font-size: 15px;
    line-height: 1.5;
  }
  .post-body pre code {
    background: transparent;
    padding: 0;
  }

  .post-body .inline-image-figure {
    margin: 48px -40px;
  }
  .post-body .inline-image {
    aspect-ratio: 3/2;
    background: var(--bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-style: italic;
    font-size: 15px;
  }
  .post-body .inline-image-caption {
    font-size: 15px;
    font-style: italic;
    color: var(--text-muted);
    text-align: center;
    margin-top: 12px;
  }
  @media (max-width: 720px) {
    .post-body .inline-image-figure { margin: 32px 0; }
  }

  .post-body img {
    margin: 48px -40px;
    max-width: calc(100% + 80px);
  }
  @media (max-width: 720px) {
    .post-body img { margin: 32px 0; max-width: 100%; }
  }

  .post-body hr {
    border: none;
    text-align: center;
    margin: 56px 0;
    color: var(--text-muted);
    font-size: 20px;
    letter-spacing: 1.2em;
    padding-left: 1.2em;
  }
  .post-body hr::before {
    content: '· · ·';
  }
</style>
