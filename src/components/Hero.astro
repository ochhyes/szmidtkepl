---
// Hero strony głównej — asymetryczny, portret wchodzi w warstwę tekstu.
// Spec §5.2. CSS przeniesiony 1:1 z docs/szmidtke-pl-ux-final.html.
import SmartImage from './SmartImage.astro';

interface Props {
  statement: string;
  sub: string;
}

const { statement, sub } = Astro.props;
---

<section class="hero" id="home">
  <div class="container">
    <div class="hero-wrap">
      <div class="hero-portrait">
        <SmartImage
          src="portret-home.jpg"
          alt="Portret Marcina Szmidtke"
          ratio="4/5"
          label="Portret główny · 800 × 1000"
          loading="eager"
          fetchpriority="high"
          sizes="(min-width: 900px) 380px, 320px"
        />
      </div>
      <div class="hero-text-wrap">
        <h1 class="hero-statement">{statement}</h1>
        <div class="hero-sub" set:html={sub} />
      </div>
    </div>
  </div>
</section>

<style>
  .hero { padding: 72px 0 120px; position: relative; }
  @media (min-width: 768px) {
    .hero { padding: 112px 0 160px; }
  }

  .hero-wrap { position: relative; max-width: 1100px; margin: 0 auto; }

  .hero-portrait {
    position: relative;
    width: 320px;
    margin-bottom: -80px;
    margin-left: 0;
  }
  @media (min-width: 900px) {
    .hero-wrap { min-height: 500px; }
    .hero-portrait {
      position: absolute;
      top: 0;
      left: 40px;
      width: 380px;
      margin: 0;
    }
  }

  .hero-text-wrap {
    padding-top: 40px;
    padding-left: 24px;
  }
  @media (min-width: 900px) {
    .hero-text-wrap {
      padding-top: 60px;
      padding-left: 440px;
      min-height: 440px;
    }
  }

  .hero-statement {
    font-size: clamp(2.25rem, 1.5rem + 3.2vw, 3.875rem);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 32px;
  }

  .hero-sub {
    font-family: var(--font-serif);
    font-size: 18px;
    font-style: italic;
    color: var(--text-muted);
    max-width: 520px;
    line-height: 1.5;
  }
</style>
