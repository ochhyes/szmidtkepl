---
// Header globalny — wordmark + nav inline (desktop) + hamburger (mobile).
// Drawer mobile obsługuje src/scripts/menu.js (inline).
const { pathname } = Astro.url;
const isActive = (path: string) => pathname === path || (path !== '/' && pathname.startsWith(path));

const navItems = [
  { href: '/blog', label: 'Piszę' },
  { href: '/o-mnie', label: 'O mnie' },
  { href: '/nie-ja', label: 'Nie ja' },
  { href: '/#newsletter', label: 'Newsletter' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<header class="site">
  <div class="container inner">
    <a href="/" class="wordmark">Marcin Szmidtke</a>
    <nav class="primary" aria-label="Główna nawigacja">
      <ul>
        {navItems.map(({ href, label }) => (
          <li>
            <a href={href} aria-current={isActive(href.split('#')[0]) ? 'page' : undefined}>{label}</a>
          </li>
        ))}
      </ul>
    </nav>
    <button class="hamburger" aria-label="Otwórz menu" aria-expanded="false" aria-controls="nav-drawer" data-nav-toggle>
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M3 6h16M3 11h16M3 16h16"/>
      </svg>
    </button>
  </div>
</header>

<nav id="nav-drawer" class="nav-drawer" aria-label="Menu mobilne" aria-hidden="true">
  <button class="close" aria-label="Zamknij menu" data-nav-close>zamknij ×</button>
  <ul>
    {navItems.map(({ href, label }) => (
      <li><a href={href}>{label}</a></li>
    ))}
  </ul>
</nav>

<script is:inline>
  (() => {
    const toggle = document.querySelector('[data-nav-toggle]');
    const drawer = document.getElementById('nav-drawer');
    const close = document.querySelector('[data-nav-close]');
    if (!toggle || !drawer) return;

    const open = () => {
      drawer.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      const firstLink = drawer.querySelector('a');
      firstLink?.focus();
    };
    const shut = () => {
      drawer.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      toggle.focus();
    };

    toggle.addEventListener('click', () => {
      drawer.getAttribute('aria-hidden') === 'true' ? open() : shut();
    });
    close?.addEventListener('click', shut);
    drawer.addEventListener('click', (e) => {
      if (e.target.tagName === 'A') shut();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') shut();
    });
  })();
</script>
