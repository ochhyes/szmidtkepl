---
// Teaser powieści Wersje — grid 1fr 2fr (desktop), okładka placeholder + opis + status badge.
// Spec §5.2 (Home teaser) i §5.6 (pełna strona).

interface Props {
  variant?: 'home' | 'full';
}

const { variant = 'home' } = Astro.props;

const heading = variant === 'home'
  ? 'Piszę powieść. Nazywa się <em>Wersje</em>.'
  : '<em>Wersje</em> to powieść o kimś, kogo nosi przez jego własne wzorce — i o tym, jak powoli uczy się to zauważyć.';

const ctaLink = variant === 'home' ? '/wersje' : null;
---

<div class="wersje-teaser">
  <div class="wersje-cover" aria-label="Okładka powieści Wersje (placeholder)">
    <em>Wersje</em>
    {variant === 'full' && <><br><br><span class="author">M. Szmidtke</span></>}
  </div>
  <div class="wersje-text">
    <h3 set:html={heading} />
    {variant === 'home' ? (
      <p>
        Powieść o kimś, kogo nosi przez jego własne wzorce — i o tym, jak powoli uczy się to zauważyć.
        O czterdziestce, na której niektóre rzeczy zaczyna się widzieć dopiero wtedy, kiedy już nie można ich cofnąć.
      </p>
    ) : (
      <>
        <p>
          Książka o pasywności, która wygląda jak normalne życie. O ludziach, w których jest się zaplątanym
          zanim się zrozumie, o co chodzi. O czterdziestce, na której niektóre rzeczy zaczyna się widzieć
          dopiero wtedy, kiedy już nie można ich cofnąć.
        </p>
        <p>
          Piszę ją od czterech lat. Teraz — rękopis w redakcji. Fragmenty pojawiają się tutaj, na stronie,
          zanim książka trafi do wydawcy.
        </p>
      </>
    )}
    {ctaLink && <a href={ctaLink} class="read-more">więcej o książce →</a>}
    <div><span class="wersje-status">rękopis w redakcji</span></div>
  </div>
</div>

<style>
  .wersje-teaser {
    display: grid;
    gap: 48px;
    align-items: center;
  }
  @media (min-width: 768px) {
    .wersje-teaser {
      grid-template-columns: 1fr 2fr;
      gap: 80px;
    }
  }

  .wersje-cover {
    aspect-ratio: 2/3;
    background: var(--bg-alt);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08), 0 6px 16px rgba(0, 0, 0, 0.04);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 28px;
    padding: 40px;
    text-align: center;
  }
  html[data-theme="dark"] .wersje-cover {
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 6px 16px rgba(0, 0, 0, 0.3);
  }
  .wersje-cover .author {
    font-size: 18px;
  }

  .wersje-text h3 {
    font-size: 28px;
    font-weight: 500;
    margin-bottom: 20px;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  @media (min-width: 768px) {
    .wersje-text h3 { font-size: 34px; }
  }
  .wersje-text p {
    color: var(--text-secondary);
    margin-bottom: 20px;
  }

  .wersje-text .read-more {
    font-family: var(--font-serif);
    font-size: 17px;
    font-style: italic;
    color: var(--accent);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 16px;
  }
  .wersje-text .read-more:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .wersje-status {
    display: inline-block;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    color: var(--accent);
    padding: 4px 14px;
    border: 1px solid var(--border);
    margin-top: 8px;
  }
</style>
