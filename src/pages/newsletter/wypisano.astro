---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Wypisane — Marcin Szmidtke"
  description="Wypisałem cię z newslettera. Bez żalu, bez przypominajek."
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <section class="block">
    <div class="container reading">
      <article class="prose">
        <h1>Wypisane</h1>

        <p class="lead">
          Wypisałem cię. Bez żalu, bez przypominajek, bez „ostatniej okazji".
        </p>

        <p>
          Jeśli kiedyś zechcesz wrócić — <a href="/#newsletter">zapis</a> jest w tym samym miejscu, co był.
        </p>

        <div class="wypisany-foot">
          <p>
            <a href="/">← wróć do strony</a>
            <span class="sep">·</span>
            <a href="/blog">teksty</a>
          </p>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .block { padding: 96px 0; }

  .prose h1 {
    font-size: 56px;
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 20px;
    color: var(--text);
  }
  @media (min-width: 768px) {
    .prose h1 { font-size: 80px; }
  }

  .prose .lead {
    font-family: var(--font-serif);
    font-size: 24px;
    line-height: 1.5;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  .prose p {
    font-size: 20px;
    line-height: 1.75;
    margin-bottom: 20px;
    color: var(--text);
  }

  .prose a {
    color: var(--accent);
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }
  .prose a:hover {
    color: var(--accent-hover);
  }

  .wypisany-foot {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--text-muted);
  }
  .wypisany-foot a {
    color: var(--text-muted);
  }
  .wypisany-foot a:hover {
    color: var(--accent);
  }
  .wypisany-foot .sep {
    margin: 0 12px;
  }
</style>
