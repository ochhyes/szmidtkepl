---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import NewsletterInline from '../components/NewsletterInline.astro';
import NieJaTeaser from '../components/NieJaTeaser.astro';
import Ornament from '../components/Ornament.astro';
import { getPublishedPosts } from '../utils/posts';
import { CATEGORY_LABEL } from '../content/config';

const latestPosts = (await getPublishedPosts()).slice(0, 3);
---

<BaseLayout
  title="Marcin Szmidtke — piszę o pasywności, schematach, drodze bez mety"
  description="Piszę o pasywności, schematach, drodze bez mety. Prowadzę zespół, działam w Fundacji Pomocja."
>
  <Hero
    statement="Piszę, żeby zauważyć, co robię, żeby nie myśleć."
    sub="Marcin Szmidtke. Doświadczony menadżer, piszę powieść, współprowadzę Fundację&nbsp;Pomocja."
  />

  <Ornament />

  <section class="block" id="blog-preview">
    <div class="container reading">
      <h2 class="section-title">Ostatnie teksty</h2>
      {latestPosts.map((post) => (
        <PostCard
          href={`/blog/${post.slug}`}
          title={post.data.title}
          lead={post.data.lead}
          date={post.data.date}
          category={CATEGORY_LABEL[post.data.category] || post.data.category}
          readingTime={post.data.readingTime}
          tags={post.data.tags}
          variant="home"
        />
      ))}
      <a href="/blog" class="all-posts-link">wszystkie teksty →</a>
    </div>
  </section>

  <Ornament />

  <NewsletterInline variant="default" id="newsletter" />

  <Ornament />

  <section class="block">
    <div class="container wide">
      <NieJaTeaser variant="home" />
    </div>
  </section>

  <Ornament />
</BaseLayout>

<style>
  .all-posts-link {
    display: inline-block;
    margin-top: 32px;
    font-family: var(--font-serif);
    font-size: 17px;
    font-style: italic;
    color: var(--accent);
    text-decoration: none;
  }
  .all-posts-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
