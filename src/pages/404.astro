---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts } from '../utils/posts';
import { CATEGORY_LABEL } from '../content/config';

const posts = (await getPublishedPosts()).slice(0, 3);
---

<BaseLayout
  title="Nie znaleziono — Marcin Szmidtke"
  description="Tego tu nie ma. Może było i już nie jest, może miało być i jeszcze nie jest."
>
  <section class="block">
    <div class="container reading">
      <div class="not-found">
        <h1>Tego tu nie ma</h1>
        <p class="message">
          Może było i już nie jest. Może miało być i jeszcze nie jest. Może źle wklejony link.
        </p>
        <nav class="not-found-nav">
          <a href="/">wróć na stronę główną →</a>
          <a href="/blog">zacznij od listy tekstów →</a>
        </nav>
        <p class="bridge-note">
          Jeśli link przyszedł z newslettera i ewidentnie nie działa — <a href="/kontakt">napisz</a>, naprawię.
        </p>
      </div>

      {posts.length > 0 && (
        <div class="not-found-feed">
          <p class="bridge">Skoro już tu jesteś — może coś z tego.</p>
          {posts.map((post) => (
            <PostCard
              href={`/blog/${post.slug}`}
              title={post.data.title}
              lead={post.data.lead}
              date={post.data.date}
              category={CATEGORY_LABEL[post.data.category] || post.data.category}
              readingTime={post.data.readingTime}
              tags={post.data.tags}
              variant="list"
            />
          ))}
          <a href="/blog/spis" class="archive-link">spis wszystkiego po kolei →</a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding: 80px 0 48px;
    text-align: left;
  }
  .not-found h1 {
    font-size: 48px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 24px;
    line-height: 1.1;
  }
  @media (min-width: 768px) {
    .not-found h1 { font-size: 72px; }
  }
  .not-found .message {
    font-size: 22px;
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 40px;
    max-width: 580px;
  }
  @media (min-width: 768px) {
    .not-found .message { font-size: 24px; }
  }
  .not-found-nav {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 32px;
  }
  .not-found-nav a {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    color: var(--accent);
    text-decoration: none;
  }
  .not-found-nav a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .not-found .bridge-note {
    font-size: 17px;
    color: var(--text-muted);
    font-style: italic;
    font-family: var(--font-serif);
    line-height: 1.6;
    max-width: 580px;
  }
  .not-found .bridge-note a {
    color: var(--accent);
  }

  .not-found-feed {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
    padding-bottom: 48px;
  }
  .not-found-feed .bridge {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    color: var(--text-muted);
    margin-bottom: 24px;
  }
  .not-found-feed .archive-link {
    display: inline-block;
    margin-top: 32px;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--accent);
    text-decoration: none;
  }
  .not-found-feed .archive-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
