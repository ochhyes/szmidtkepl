---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import CategoryFilter from '../../../components/CategoryFilter.astro';
import { getPublishedPosts } from '../../../utils/posts';
import { CATEGORY_ORDER, CATEGORY_LABEL } from '../../../content/config';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  return CATEGORY_ORDER.map((category) => ({
    params: { nazwa: category },
    props: {
      category,
      posts: posts.filter((p) => p.data.category === category),
    },
  }));
}) satisfies GetStaticPaths;

const { category, posts } = Astro.props;
const label = CATEGORY_LABEL[category] || category;
---

<BaseLayout
  title={`${label.charAt(0).toUpperCase() + label.slice(1)} — Marcin Szmidtke`}
  description={`Wpisy z kategorii „${label}" — Marcin Szmidtke.`}
>
  <section class="blog-header">
    <div class="container reading">
      <h1>Piszę</h1>
      <p class="subtitle">
        Kategoria: <em>{label}</em>
      </p>
      <CategoryFilter active={category} />
    </div>
  </section>

  <section class="block">
    <div class="container reading">
      {posts.length === 0 ? (
        <p class="empty">Nic w tej kategorii. Jeszcze.</p>
      ) : (
        posts.map((post) => (
          <PostCard
            href={`/blog/${post.slug}`}
            title={post.data.title}
            lead={post.data.lead}
            date={post.data.date}
            category={label}
            readingTime={post.data.readingTime}
            variant="list"
          />
        ))
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-header {
    padding: 80px 0 24px;
    text-align: left;
  }
  .blog-header h1 {
    font-size: 48px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  @media (min-width: 768px) {
    .blog-header h1 { font-size: 64px; }
  }
  .blog-header .subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    color: var(--text-secondary);
  }
  .empty {
    color: var(--text-secondary);
    font-style: italic;
    padding: 48px 0;
  }
</style>
