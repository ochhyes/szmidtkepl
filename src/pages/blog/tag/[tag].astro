---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getPublishedPosts } from '../../../utils/posts';
import { CATEGORY_LABEL } from '../../../content/config';
import { slugify } from '../../../utils/slug';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  const tagMap = new Map<string, { label: string; posts: typeof posts }>();

  for (const post of posts) {
    const tags = post.data.tags ?? [];
    for (const tag of tags) {
      const slug = slugify(tag);
      if (!tagMap.has(slug)) {
        tagMap.set(slug, { label: tag, posts: [] });
      }
      tagMap.get(slug)!.posts.push(post);
    }
  }

  return Array.from(tagMap.entries()).map(([slug, entry]) => ({
    params: { tag: slug },
    props: { tagLabel: entry.label, posts: entry.posts },
  }));
}) satisfies GetStaticPaths;

const { tagLabel, posts } = Astro.props;
---

<BaseLayout
  title={`Tag: ${tagLabel} — Marcin Szmidtke`}
  description={`Wpisy oznaczone tagiem „${tagLabel}" — Marcin Szmidtke.`}
>
  <section class="blog-header">
    <div class="container reading">
      <h1>Piszę</h1>
      <p class="subtitle">
        Tag: <em>{tagLabel}</em>
      </p>
    </div>
  </section>

  <section class="block">
    <div class="container reading">
      {posts.length === 0 ? (
        <p class="empty">Nic pod tym tagiem. Jeszcze.</p>
      ) : (
        posts.map((post) => (
          <PostCard
            href={`/blog/${post.slug}`}
            title={post.data.title}
            lead={post.data.lead}
            date={post.data.date}
            category={CATEGORY_LABEL[post.data.category] || post.data.category}
            readingTime={post.data.readingTime}
            tags={post.data.tags}
            variant="list"
          />
        ))
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-header {
    padding: 80px 0 24px;
    text-align: left;
  }
  .blog-header h1 {
    font-size: 48px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  @media (min-width: 768px) {
    .blog-header h1 { font-size: 64px; }
  }
  .blog-header .subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    color: var(--text-secondary);
  }
  .empty {
    color: var(--text-secondary);
    font-style: italic;
    padding: 48px 0;
  }
</style>
