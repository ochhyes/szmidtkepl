---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import Pagination from '../../components/Pagination.astro';
import { getPublishedPosts, formatPolishDate } from '../../utils/posts';
import { CATEGORY_LABEL } from '../../content/config';

const POSTS_PER_PAGE = 10;

const posts = await getPublishedPosts();

// Paginacja — w v1 i tak mamy 3 wpisy, więc pagination się nie wyświetli.
// Logika jest jednak gotowa: /blog = pierwsze 10, /blog/2 = kolejne itd. (niewdrożone w v1).
const page = posts.slice(0, POSTS_PER_PAGE);
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
---

<BaseLayout
  title="Piszę — Marcin Szmidtke"
  description="O pasywności, schematach, drodze bez mety. Jeden tekst w tygodniu, czasem rzadziej."
>
  <section class="blog-header">
    <div class="container reading">
      <h1>Piszę</h1>
      <p class="subtitle">O pasywności, schematach, drodze bez mety. Jeden tekst w tygodniu, czasem rzadziej.</p>
      <CategoryFilter active="all" />
    </div>
  </section>

  <section class="block" id="blog">
    <div class="container reading">
      {page.length === 0 ? (
        <p class="empty">Nie ma jeszcze żadnych tekstów. Wróć za kilka dni.</p>
      ) : (
        page.map((post) => (
          <PostCard
            href={`/blog/${post.slug}`}
            title={post.data.title}
            lead={post.data.lead}
            date={post.data.date}
            category={CATEGORY_LABEL[post.data.category] || post.data.category}
            readingTime={post.data.readingTime}
            variant="list"
          />
        ))
      )}
      {totalPages > 1 && (
        <Pagination
          prevUrl={null}
          nextUrl={totalPages > 1 ? '/blog/2' : null}
        />
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-header {
    padding: 80px 0 24px;
    text-align: left;
  }
  .blog-header h1 {
    font-size: 48px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  @media (min-width: 768px) {
    .blog-header h1 { font-size: 64px; }
  }
  .blog-header .subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    color: var(--text-secondary);
    max-width: 560px;
  }
  .empty {
    color: var(--text-secondary);
    font-style: italic;
    padding: 48px 0;
  }
</style>
