---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import Pagination from '../../components/Pagination.astro';
import { getPublishedPosts } from '../../utils/posts';
import { CATEGORY_LABEL } from '../../content/config';

const POSTS_PER_PAGE = 10;

const posts = await getPublishedPosts();

// Paginacja — w v1 i tak mamy kilka wpisów, więc pagination się nie wyświetli.
// Logika jest jednak gotowa: /blog = pierwsze 10, /blog/2 = kolejne itd. (niewdrożone w v1).
const page = posts.slice(0, POSTS_PER_PAGE);
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
---

<BaseLayout
  title="Teksty — Marcin Szmidtke"
  description="Eseje, obserwacje, fragmenty powieści. List raz na dwa tygodnie."
>
  <section class="blog-header">
    <div class="container reading">
      <h1>Teksty</h1>
      <p class="lead">
        <em>Zbieram tu trzy rzeczy: eseje, obserwacje, fragmenty powieści.</em>
      </p>

      <div class="blog-intro">
        <p>
          <strong>Eseje.</strong> Dłuższe. Jedna myśl, raczej rozpisana niż skondensowana.
          Piszę je kilka razy w roku, kiedy coś się w końcu ułoży w głowie na tyle,
          żeby miało sens dla kogoś poza mną.
        </p>
        <p>
          <strong>Obserwacje.</strong> Krótkie. To, co zauważyłem w tygodniu,
          i czego nie dało się powiedzieć dwoma zdaniami.
        </p>
        <p>
          <strong>Fragmenty.</strong> Kawałki powieści <a href="/nie-ja"><em>Nie ja</em></a> —
          pierwsze wersje, czasem po redakcji, czasem surowe.
          Zostawiam je w widoku, żeby było widać, jak to się rzeczywiście pisze.
        </p>

        <div class="blog-sep" aria-hidden="true">· · ·</div>

        <p>
          Nic nie jest tu w porządku chronologicznym — data mówi mniej niż „co z czym się łączy".
          Jeśli czegoś szukasz — spójrz w tagi albo w <a href="/blog/spis">spis po kolei</a>.
        </p>

        <p>
          Jeżeli chcesz dostawać teksty mailem, zamiast polować po stronie —
          <a href="/#newsletter">zapisz się do newslettera</a>. Raz na dwa tygodnie, jeden list.
        </p>
      </div>

      <CategoryFilter active="all" />
    </div>
  </section>

  <section class="block" id="blog">
    <div class="container reading">
      {page.length === 0 ? (
        <p class="empty">Nie ma jeszcze żadnych tekstów. Wróć za kilka dni.</p>
      ) : (
        page.map((post) => (
          <PostCard
            href={`/blog/${post.slug}`}
            title={post.data.title}
            lead={post.data.lead}
            date={post.data.date}
            category={CATEGORY_LABEL[post.data.category] || post.data.category}
            readingTime={post.data.readingTime}
            tags={post.data.tags}
            variant="list"
          />
        ))
      )}
      {totalPages > 1 && (
        <Pagination
          prevUrl={null}
          nextUrl={totalPages > 1 ? '/blog/2' : null}
        />
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-header {
    padding: 80px 0 24px;
    text-align: left;
  }
  .blog-header h1 {
    font-size: 48px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 20px;
  }
  @media (min-width: 768px) {
    .blog-header h1 { font-size: 64px; }
  }
  .blog-header .lead {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 32px;
  }
  .blog-intro p {
    font-size: 18px;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 16px;
  }
  .blog-intro p strong {
    font-weight: 600;
  }
  .blog-intro a {
    color: var(--accent);
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }
  .blog-intro a:hover {
    color: var(--accent-hover);
  }
  .blog-intro .blog-sep {
    font-family: var(--font-serif);
    color: var(--text-muted);
    letter-spacing: 0.6em;
    margin: 24px 0 16px;
    font-size: 16px;
    user-select: none;
  }
  .empty {
    color: var(--text-secondary);
    font-style: italic;
    padding: 48px 0;
  }
</style>
