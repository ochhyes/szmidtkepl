---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostBody from '../../components/PostBody.astro';
import PostFooter from '../../components/PostFooter.astro';
import PostTags from '../../components/PostTags.astro';
import { getPublishedPosts, getRelatedPosts, getAdjacentPosts, formatPolishDate } from '../../utils/posts';
import { CATEGORY_LABEL } from '../../content/config';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await post.render();
const related = await getRelatedPosts(post, 2);
const allPosts = await getPublishedPosts();
const { prev, next } = getAdjacentPosts(post.slug, allPosts);

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://szmidtke.pl';
const canonical = new URL(`/blog/${post.slug}`, siteUrl).toString();
const ogImage = post.data.ogImage ?? new URL(`/og/${post.slug}.png`, siteUrl).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      headline: post.data.title,
      description: post.data.lead,
      datePublished: post.data.date.toISOString(),
      author: {
        '@type': 'Person',
        name: 'Marcin Szmidtke',
        url: siteUrl,
      },
      image: ogImage,
      mainEntityOfPage: canonical,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Marcin Szmidtke', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: 'Piszę', item: new URL('/blog', siteUrl).toString() },
        { '@type': 'ListItem', position: 3, name: post.data.title, item: canonical },
      ],
    },
  ],
};

const categoryLabel = CATEGORY_LABEL[post.data.category] || post.data.category;
const meta = `${formatPolishDate(post.data.date)} — ${categoryLabel}, ${post.data.readingTime}`;
---

<BaseLayout
  title={`${post.data.title} — Marcin Szmidtke`}
  description={post.data.lead}
  ogType="article"
  publishedTime={post.data.date.toISOString()}
  canonical={canonical}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <section class="post-block">
    <div class="container">
      <article class="post-single">
        <div class="meta">{meta}</div>
        {post.data.tags && post.data.tags.length > 0 && <PostTags tags={post.data.tags} />}
        <h1>{post.data.title}</h1>
        <p class="lead-para">{post.data.lead}</p>
        <PostBody>
          <Content />
        </PostBody>
      </article>
      <PostFooter related={related} prev={prev} next={next} url={canonical} />
    </div>
  </section>
</BaseLayout>

<style>
  .post-block { padding: 96px 0; }
  .post-single {
    max-width: var(--reading-w);
    margin: 0 auto;
  }
  .post-single .meta { margin-bottom: 12px; }
  .post-single :global(.post-tags) { margin-bottom: 20px; }
  .post-single h1 {
    font-size: 40px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 32px;
  }
  @media (min-width: 768px) {
    .post-single h1 { font-size: 54px; }
  }

  .post-single .lead-para {
    font-size: 22px;
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 48px;
  }
</style>
