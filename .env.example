# Newsletter — Buttondown API (iteracja 5)
# Pobierz klucz z https://buttondown.email/settings/programming
BUTTONDOWN_API_KEY=

# URL publiczny (używany w meta tags, RSS, sitemap)
PUBLIC_SITE_URL=https://szmidtke.pl

# Plausible analytics — self-hosted (iteracja 16)
# Po ustawieniu PUBLIC_PLAUSIBLE_DOMAIN strona ładuje skrypt z analytics.szmidtke.pl.
# Pusty = brak trackingu (domyślnie).
PUBLIC_PLAUSIBLE_DOMAIN=

# --- Sekrety Plausible (server-side, NIE public) ---
# Wygeneruj: openssl rand -base64 64
PLAUSIBLE_SECRET_KEY_BASE=
# Wygeneruj: openssl rand -base64 32
PLAUSIBLE_TOTP_VAULT_KEY=
# Hasło do wewnętrznego Postgres (dowolne — używane tylko w sieci plausible_net).
PLAUSIBLE_POSTGRES_PASSWORD=postgres
