<clickhouse>
    <logger>
        <level>warning</level>
        <console>true</console>
    </logger>

    <!-- Wyłączenie query logów w ClickHouse — nie potrzebujemy ich, redukuje I/O. -->
    <query_thread_log remove="remove"/>
    <query_log remove="remove"/>
    <text_log remove="remove"/>
    <trace_log remove="remove"/>
    <metric_log remove="remove"/>
    <asynchronous_metric_log remove="remove"/>
    <session_log remove="remove"/>
    <part_log remove="remove"/>

    <!-- VPS bez IPv6 — default `<listen_host>::</listen_host>` z docker_related_config.xml
         nie bind'uje i clickhouse leci w unhealthy. `listen_try=1` pozwala pominąć
         nieudane listeny, a drugi `listen_host` na 0.0.0.0 daje faktyczny listener IPv4.
         (`replace="replace"` nie zadziałało przy bind mount override — zostawiamy add.) -->
    <listen_try>1</listen_try>
    <listen_host>0.0.0.0</listen_host>
</clickhouse>
