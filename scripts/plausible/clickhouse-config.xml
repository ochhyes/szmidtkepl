<clickhouse>
    <logger>
        <level>warning</level>
        <console>true</console>
    </logger>

    <!-- Wyłączenie query logów w ClickHouse — nie potrzebujemy ich, redukuje I/O. -->
    <query_thread_log remove="remove"/>
    <query_log remove="remove"/>
    <text_log remove="remove"/>
    <trace_log remove="remove"/>
    <metric_log remove="remove"/>
    <asynchronous_metric_log remove="remove"/>
    <session_log remove="remove"/>
    <part_log remove="remove"/>

    <!-- VPS bez IPv6 — default `::` nie może bind'ować i clickhouse leci w unhealthy.
         Nadpisanie na IPv4-only. -->
    <listen_host replace="replace">0.0.0.0</listen_host>
</clickhouse>
