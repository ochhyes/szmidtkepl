# =============================================================================
# Referencyjny blok nginx dla szmidtke.pl
# Wklej do /etc/nginx/sites-available/szmidtke.pl i zrób symlink do sites-enabled.
# SSL przez Certbot (letsencrypt) — uruchom `certbot --nginx -d szmidtke.pl`
# po uruchomieniu tego bloku (certbot sam doda 443 + redirect 80→443).
# =============================================================================

# =============================================================================
# www → non-www 301 (iter 20). Kanoniczna domena: szmidtke.pl (bez www).
# Certbot -d www.szmidtke.pl doda ssl_certificate do bloku 443 poniżej.
# =============================================================================
server {
    listen 80;
    server_name www.szmidtke.pl;
    return 301 https://szmidtke.pl$request_uri;
}
server {
    listen 443 ssl http2;
    server_name www.szmidtke.pl;
    # ssl_certificate / ssl_certificate_key — dodaje certbot po
    # `sudo certbot --nginx -d www.szmidtke.pl`.
    return 301 https://szmidtke.pl$request_uri;
}

server {
    listen 80;
    server_name szmidtke.pl;

    # Rozmiar body — wystarczy skromnie, formularze tekstowe.
    client_max_body_size 1m;

    # Kompresja — szybszy transfer HTML/CSS/JS/XML/SVG.
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/javascript
        application/xml
        application/json
        application/rss+xml
        application/atom+xml
        image/svg+xml;

    # Security headers — standard 2026 (Mozilla Observatory grade A).
    # `always` — wysyłaj także na 4xx/5xx (domyślnie nginx pomija).
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
    # CSP — pierwsza wersja. Astro generuje kilka inline'owych script tagów
    # (theme setter w BaseLayout, menu drawer, newsletter Plausible event) —
    # dlatego `'unsafe-inline'` w script-src. TODO Sprint 4: refactor na nonce
    # (Astro 5 wspiera `Astro.csp`).
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://analytics.szmidtke.pl; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://analytics.szmidtke.pl; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" always;

    # Long cache dla assetów z fingerprintem (Astro generuje nazwy z hashami).
    location ~* \.(avif|webp|jpg|jpeg|png|svg|gif|woff2|woff|ttf|eot)$ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # OG images i RSS — krótszy cache, mogą się zmienić przy nowym wpisie.
    location ~* ^/(og/|og-default\.png|rss\.xml|sitemap.*\.xml) {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        expires 1h;
        add_header Cache-Control "public";
    }

    # Pozostałe — HTML, API — brak cache po stronie nginx, niech odpowiada aplikacja.
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;
    }

    # /api/ — POST tylko, timeouty krótkie (Buttondown też jest szybki).
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 10s;
    }
}

# =============================================================================
# Plausible self-hosted — iteracja 16
# Po uruchomieniu `docker compose up -d plausible` kontener nasłuchuje na
# 127.0.0.1:8000. Dodaj DNS `analytics.szmidtke.pl` → IP VPS i włącz SSL
# przez `sudo certbot --nginx -d analytics.szmidtke.pl` po restarcie nginx.
# =============================================================================
server {
    listen 80;
    server_name analytics.szmidtke.pl;

    gzip on;
    gzip_types application/javascript application/json text/css;

    # Zablokuj indeksowanie panelu Plausible — dashboard nie ma czego szukać w SERP.
    location = /robots.txt {
        add_header Content-Type text/plain;
        return 200 "User-agent: *\nDisallow: /\n";
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;

        # WebSockets dla live dashboard.
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
