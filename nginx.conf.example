# =============================================================================
# Referencyjny blok nginx dla szmidtke.pl
# Wklej do /etc/nginx/sites-available/szmidtke.pl i zrób symlink do sites-enabled.
#
# KOLEJNOŚĆ PIERWSZEGO SETUPU (obowiązkowa):
# 1. certbot certonly -d szmidtke.pl -d www.szmidtke.pl -d analytics.szmidtke.pl
#    (certonly, NIE --nginx — pobiera cert bez modyfikowania configu)
# 2. sudo cp nginx.conf.example /etc/nginx/sites-available/szmidtke.pl
# 3. sudo nginx -t && sudo systemctl reload nginx
#
# REDEPLOY configu: powtórz kroki 2-3. NIE odpalaj `certbot --nginx` — modyfikuje
# config i psuje idempotentność (ta regresja właśnie wywaliła 403 w Sprint 3 iter 20).
# Renewal przez `sudo certbot renew` lub systemd timer — nie rusza configu nginx.
# =============================================================================

# =============================================================================
# Redirect 80 → 443 dla szmidtke.pl (kanoniczna domena)
# =============================================================================
server {
    listen 80;
    server_name szmidtke.pl;
    return 301 https://szmidtke.pl$request_uri;
}

# =============================================================================
# www → non-www 301 (iter 20). Kanoniczna domena: szmidtke.pl (bez www).
# =============================================================================
server {
    listen 80;
    server_name www.szmidtke.pl;
    return 301 https://szmidtke.pl$request_uri;
}
server {
    listen 443 ssl;
    http2 on;
    server_name www.szmidtke.pl;

    ssl_certificate /etc/letsencrypt/live/www.szmidtke.pl/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/www.szmidtke.pl/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://szmidtke.pl$request_uri;
}

# =============================================================================
# Główny blok szmidtke.pl — 443 SSL, proxy do kontenera Astro na 127.0.0.1:3000
# =============================================================================
server {
    listen 443 ssl;
    http2 on;
    server_name szmidtke.pl;

    ssl_certificate /etc/letsencrypt/live/szmidtke.pl/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/szmidtke.pl/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Rozmiar body — wystarczy skromnie, formularze tekstowe.
    client_max_body_size 1m;

    # Kompresja — szybszy transfer HTML/CSS/JS/XML/SVG.
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/javascript
        application/xml
        application/json
        application/rss+xml
        application/atom+xml
        image/svg+xml;

    # Security headers — standard 2026 (Mozilla Observatory grade A).
    # `always` — wysyłaj także na 4xx/5xx (domyślnie nginx pomija).
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
    # CSP — pierwsza wersja. Astro generuje kilka inline'owych script tagów
    # (theme setter w BaseLayout, menu drawer, newsletter Plausible event) —
    # dlatego `'unsafe-inline'` w script-src. TODO Sprint 4: refactor na nonce
    # (Astro 5 wspiera `Astro.csp`).
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://analytics.szmidtke.pl; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://analytics.szmidtke.pl; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" always;

    # Long cache dla assetów z fingerprintem (Astro generuje nazwy z hashami).
    location ~* \.(avif|webp|jpg|jpeg|png|svg|gif|woff2|woff|ttf|eot)$ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # OG images i RSS — krótszy cache, mogą się zmienić przy nowym wpisie.
    location ~* ^/(og/|og-default\.png|rss\.xml|sitemap.*\.xml) {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        expires 1h;
        add_header Cache-Control "public";
    }

    # Pozostałe — HTML, API — brak cache po stronie nginx, niech odpowiada aplikacja.
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;
    }

    # /api/ — POST tylko, timeouty krótkie (Buttondown też jest szybki).
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 10s;
    }
}

# =============================================================================
# Plausible self-hosted — iteracja 16
# Po uruchomieniu `docker compose up -d plausible` kontener nasłuchuje na
# 127.0.0.1:8000. Przed kopiowaniem tego configu:
#   sudo certbot certonly -d analytics.szmidtke.pl
# =============================================================================
server {
    listen 80;
    server_name analytics.szmidtke.pl;
    return 301 https://analytics.szmidtke.pl$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name analytics.szmidtke.pl;

    ssl_certificate /etc/letsencrypt/live/analytics.szmidtke.pl/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/analytics.szmidtke.pl/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    gzip on;
    gzip_types application/javascript application/json text/css;

    # Zablokuj indeksowanie panelu Plausible — dashboard nie ma czego szukać w SERP.
    location = /robots.txt {
        add_header Content-Type text/plain;
        return 200 "User-agent: *\nDisallow: /\n";
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;

        # WebSockets dla live dashboard.
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
